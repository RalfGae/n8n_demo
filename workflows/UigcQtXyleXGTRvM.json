    {
      "parameters": {
        "jsCode": "const files = $('Aggregate files').first().json.files;\nconst sheetRows = $input.all().map(item => item.json);\nconst existingIds = new Set(\n  sheetRows.map(r => r.receipt_id).filter(id => !!id)\n);\nconst force = !!$('On form submission').first().json['Force reprocess'];\nconst toProcess = force ? files : files.filter(f => !existingIds.has(f.id));\nconst filteredToProcess = toProcess.filter(f =>\n  !f.mimeType?.startsWith('application/vnd.google-apps.'));\nreturn filteredToProcess.map(f => ({ json: f }));"
      },
