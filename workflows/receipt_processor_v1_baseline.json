      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"title\": \"ReceiptValidation\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"receipt_info\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"date\": { \"type\": \"string\", \"format\": \"date\", \"title\": \"Receipt Date\" },\n        \"store\": { \"type\": \"string\", \"title\": \"Store Name\" },\n        \"currency\": { \"type\": \"string\", \"title\": \"Currency\" },\n        \"total_amount\": { \"type\": \"number\", \"title\": \"Total Amount on Receipt\" },\n        \"tax_amount\": { \"type\": \"number\", \"title\": \"Total Tax Amount\", \"default\": 0 },\n        \"subtotal\": { \"type\": \"number\", \"title\": \"Subtotal before tax\", \"default\": 0 }\n      },\n      \"required\": [\"date\", \"store\", \"currency\", \"total_amount\"]\n    },\n    \"items\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n           \"date\": { \"type\": \"string\", \"format\": \"date\", \"title\": \"Receipt Date\" },\n        \"store\": { \"type\": \"string\", \"title\": \"Store Name\" },\n        \"currency\": { \"type\": \"string\", \"title\": \"Currency\" },\n          \"category\": { \"type\": \"string\", \"title\": \"Item Category\" },\n          \"name\": { \"type\": \"string\", \"title\": \"Item Name\" },\n          \"price\": { \"type\": \"number\", \"title\": \"Item Price\" },\n          \"quantity\": { \"type\": \"number\", \"title\": \"Quantity\", \"default\": 1 }\n        },\n        \"required\": [\"date\", \"store\", \"currency\", \"category\", \"name\", \"price\"],\n        \"additionalProperties\": false\n      }\n    }\n  },\n  \"required\": [\"receipt_info\", \"items\"],\n  \"additionalProperties\": false\n}\n"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
