# n8n persistent data
n8n_data/
# persistent user data
my-files/
# backup files
backups/

# n8n workflow raw exports (contain sensitive values, never commit)
workflows/*_raw.json
# Local workflow var mapping (contains sensitive values)
utils/workflow_var_mapping.json
# Temp export location
/tmp/n8n_export/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Environment variables
.env

# Credentials
.credentials/

# Docker
*.log

# VS Code settings
.vscode/

# macOS
.DS_Store

# Python egg info
*.egg-info/

dist/
build/
