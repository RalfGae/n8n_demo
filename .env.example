# Environment Variables for n8n Demo
# Copy this file to .env and fill in your actual values

# OpenAI API Key for AI processing workflows
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Gemini API Key for Google AI workflows  
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# n8n Workflow Variables — copy from utils/workflow_var_mapping.example.json
N8N_DRIVE_FOLDER_ID_UNSORTIERT=your_folder_id_here
N8N_SHEET_RECHNUNGEN_ID=your_spreadsheet_id_here
N8N_SHEET_EINZELPOSTEN_GID=gid=0
N8N_SHEET_GESAMTPOSTEN_GID=0
N8N_NOTIFICATION_EMAIL=your@email.here